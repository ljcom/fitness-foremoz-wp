{
  "name": "foremoz-fitness-read-model-v1",
  "namespace_format": "foremoz:fitness:<tenant_id>",
  "chain_format": "branch:<branch_id>|core",
  "checkpoint_table": "read.rm_checkpoint",
  "tables": [
    {
      "name": "read.rm_member",
      "primary_key": ["tenant_id", "member_id"],
      "columns": [
        "tenant_id",
        "branch_id",
        "member_id",
        "full_name",
        "phone",
        "status",
        "registered_at",
        "updated_at"
      ],
      "query_use": "member list dan profile header"
    },
    {
      "name": "read.rm_subscription_active",
      "primary_key": ["tenant_id", "subscription_id"],
      "columns": [
        "tenant_id",
        "branch_id",
        "subscription_id",
        "member_id",
        "plan_id",
        "status",
        "start_date",
        "end_date",
        "freeze_until",
        "updated_at"
      ],
      "query_use": "cek subscription aktif untuk checkin"
    },
    {
      "name": "read.rm_attendance_daily",
      "primary_key": ["tenant_id", "branch_id", "attendance_date"],
      "columns": [
        "tenant_id",
        "branch_id",
        "attendance_date",
        "total_checkin",
        "unique_member_count",
        "updated_at"
      ],
      "query_use": "rekap attendance harian"
    },
    {
      "name": "read.rm_class_availability",
      "primary_key": ["tenant_id", "class_id"],
      "columns": [
        "tenant_id",
        "branch_id",
        "class_id",
        "class_name",
        "start_at",
        "end_at",
        "capacity",
        "booked_count",
        "available_slots",
        "updated_at"
      ],
      "query_use": "kapasitas kelas dan slot tersedia"
    },
    {
      "name": "read.rm_booking_list",
      "primary_key": ["tenant_id", "booking_id"],
      "columns": [
        "tenant_id",
        "branch_id",
        "booking_id",
        "class_id",
        "booking_kind",
        "member_id",
        "guest_name",
        "status",
        "booked_at",
        "canceled_at",
        "attendance_confirmed_at",
        "updated_at"
      ],
      "query_use": "roster booking per class"
    },
    {
      "name": "read.rm_pt_balance",
      "primary_key": ["tenant_id", "pt_package_id"],
      "columns": [
        "tenant_id",
        "branch_id",
        "pt_package_id",
        "member_id",
        "trainer_id",
        "total_sessions",
        "consumed_sessions",
        "remaining_sessions",
        "last_session_at",
        "updated_at"
      ],
      "query_use": "saldo PT session member"
    },
    {
      "name": "read.rm_payment_queue",
      "primary_key": ["tenant_id", "payment_id"],
      "columns": [
        "tenant_id",
        "branch_id",
        "payment_id",
        "member_id",
        "subscription_id",
        "amount",
        "currency",
        "method",
        "proof_url",
        "status",
        "recorded_at",
        "reviewed_at",
        "reviewed_by",
        "updated_at"
      ],
      "query_use": "antrian konfirmasi payment"
    },
    {
      "name": "read.rm_dashboard",
      "primary_key": ["tenant_id", "branch_id", "dashboard_date"],
      "columns": [
        "tenant_id",
        "branch_id",
        "dashboard_date",
        "active_subscription_count",
        "today_checkin_count",
        "today_booking_count",
        "pending_payment_count",
        "updated_at"
      ],
      "query_use": "ringkasan operasional harian"
    }
  ]
}
